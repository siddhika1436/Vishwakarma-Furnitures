# ─── MySQL ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=vishwakarma_furnitures

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Server ─────────────────────────────────────────────────
PORT=4000
ADMIN_EMAIL=deepakschaudhari07@gmail.com

# ─── CORS: your deployed frontend URL ───────────────────────
FRONTEND_URL=http://localhost:5173

# ─── SMTP (Gmail) ───────────────────────────────────────────
# For Gmail: enable 2FA → Settings → App Passwords → Generate
# Choose "Mail" + "Windows Computer" → Copy 16-char password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# ─── Razorpay ───────────────────────────────────────────────
# Get from https://dashboard.razorpay.com → Settings → API Keys
# Use test keys during development (rzp_test_...)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret (set when creating webhook in Razorpay Dashboard)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Deployment ─────────────────────────────────────────────
NODE_ENV=development
